# Copy this file to `.env` and fill in your key. `.env` is git-ignored.

# --- Custom OpenAI-compatible LLM gateway (Gemini Flash 2.5 behind a proxy) ---
# When CUSTOM_LLM_URL and CUSTOM_LLM_API_KEY are both set, the app uses this
# gateway (X-API-KEY auth, OpenAI chat-completions wire format) instead of the
# direct Gemini API. CUSTOM_LLM_MODEL defaults to gemini-2-5-flash if omitted.
# v2 = standard chat completions; v3 = TrustAI-enabled chat completions.
CUSTOM_LLM_URL=https://quasarmarket.coforge.com/qag/llmrouter-api/v2/chat/completions
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=gemini-2-5-flash
